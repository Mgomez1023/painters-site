{
  "rewrites": [
    {
      "source": "/photos",
      "destination": "/index.html"
    },
    {
      "source": "/photos/",
      "destination": "/index.html"
    },
    {
      "source": "/services",
      "destination": "/index.html"
    },
    {
      "source": "/services/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/areas",
      "destination": "/index.html"
    },
    {
      "source": "/areas/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/blog",
      "destination": "/index.html"
    },
    {
      "source": "/blog/:path*",
      "destination": "/index.html"
    }
  ]
}
