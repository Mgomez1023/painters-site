# Resend API key used by the Vercel `/api/contact` route.
RESEND_API_KEY="re_123"

# Brevo API key and list ID used by the Vercel `/api/email-signup` route.
BREVO_API_KEY=your_brevo_api_key_here
BREVO_EMAIL_LIST_ID=your_list_id_here

# Reserved for future email campaign/admin notification work.
EMAIL_SIGNUP_FROM_NAME="Marom Painting"
EMAIL_SIGNUP_ADMIN_NOTIFY_EMAIL="marting2046@gmail.com"

# Vercel Blob token used by the portfolio photo API routes.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_123"

# Single admin account used by the footer-only portfolio login.
PORTFOLIO_ADMIN_EMAIL="owner@example.com"
PORTFOLIO_ADMIN_PASSWORD="replace-with-a-strong-password"

# Long random string used to sign the admin session cookie.
PORTFOLIO_ADMIN_SESSION_SECRET="replace-with-a-long-random-secret"
